import React, { useState, useEffect } from 'react';
import {
  Card,
  Table,
  Button,
  Space,
  message,
  Popconfirm,
  Tag,
  Modal,
  Form,
  Input,
  Switch,
  Divider,
  Typography,
} from 'antd';
import {
  SlackOutlined,
  PlusOutlined,
  SyncOutlined,
  DeleteOutlined,
  EditOutlined,
  UserOutlined,
  SendOutlined,
} from '@ant-design/icons';
import type { ColumnsType } from 'antd/es/table';
import { slackConfigApi, SlackConfig } from '../api/slack-config';

const { Title, Text } = Typography;
const { TextArea } = Input;

export const SlackNotification: React.FC = () => {
  const [loading, setLoading] = useState(false);
  const [configs, setConfigs] = useState<SlackConfig[]>([]);
  const [testingIds, setTestingIds] = useState<Set<string>>(new Set());
  const [modalOpen, setModalOpen] = useState(false);
  const [editingConfig, setEditingConfig] = useState<SlackConfig | null>(null);
  const [form] = Form.useForm();

  // Test panels
  const [testEmailModalOpen, setTestEmailModalOpen] = useState(false);
  const [testDmModalOpen, setTestDmModalOpen] = useState(false);
  const [testForm] = Form.useForm();
  const [dmForm] = Form.useForm();
  const [testingEmail, setTestingEmail] = useState(false);
  const [testingDm, setTestingDm] = useState(false);

  useEffect(() => {
    fetchConfigs();
  }, []);

  const fetchConfigs = async () => {
    setLoading(true);
    try {
      const response = await slackConfigApi.getAll();
      setConfigs(response.data);
    } catch (error: any) {
      message.error('Slack 설정 목록을 불러오는데 실패했습니다');
    } finally {
      setLoading(false);
    }
  };

  const handleTest = async (id: string, name: string) => {
    setTestingIds((prev) => new Set(prev).add(id));
    try {
      // Fetch the full config with actual token (not masked)
      const fullConfigResponse = await slackConfigApi.getById(id);
      const fullConfig = fullConfigResponse.data;

      const response = await slackConfigApi.testConnection(fullConfig.botToken);
      if (response.data.success) {
        message.success({
          content: (
            <div>
              <strong>{name}</strong>
              <br />
              Slack 연결 테스트 성공
              <br />
              워크스페이스: {response.data.workspace}
              <br />
              봇: {response.data.botUser}
            </div>
          ),
          duration: 5,
        });
      } else {
        message.error({
          content: (
            <div>
              <strong>{name}</strong>
              <br />
              Slack 연결 테스트 실패
            </div>
          ),
          duration: 5,
        });
      }
    } catch (error: any) {
      const errorMsg = error.response?.data?.error || error.message || '알 수 없는 오류';
      message.error({
        content: (
          <div>
            <strong>{name}</strong>
            <br />
            연결 실패: {errorMsg}
          </div>
        ),
        duration: 8,
      });
    } finally {
      setTestingIds((prev) => {
        const newSet = new Set(prev);
        newSet.delete(id);
        return newSet;
      });
    }
  };

  const handleDelete = async (id: string, name: string) => {
    try {
      await slackConfigApi.delete(id);
      message.success(`"${name}" Slack 설정이 삭제되었습니다`);
      fetchConfigs();
    } catch (error: any) {
      message.error('삭제 실패: ' + error.message);
    }
  };

  const handleEdit = async (config: SlackConfig) => {
    setEditingConfig(config);

    // Full token is not returned from API (only last 8 chars), so we need to fetch it
    try {
      const response = await slackConfigApi.getById(config.id);
      form.setFieldsValue(response.data);
    } catch (error) {
      message.error('설정을 불러오는데 실패했습니다');
    }
    setModalOpen(true);
  };

  const handleAdd = () => {
    setEditingConfig(null);
    form.resetFields();
    form.setFieldsValue({ isActive: false });
    setModalOpen(true);
  };

  const handleModalOk = async () => {
    try {
      const values = await form.validateFields();

      if (editingConfig) {
        await slackConfigApi.update(editingConfig.id, values);
        message.success('Slack 설정이 수정되었습니다');
      } else {
        await slackConfigApi.create(values);
        message.success('Slack 설정이 추가되었습니다');
      }

      setModalOpen(false);
      form.resetFields();
      fetchConfigs();
    } catch (error: any) {
      if (error.errorFields) {
        // Validation error
        return;
      }
      message.error('저장 실패: ' + (error.response?.data?.error || error.message));
    }
  };

  const handleModalCancel = () => {
    setModalOpen(false);
    form.resetFields();
    setEditingConfig(null);
  };

  // Test email lookup
  const handleTestEmail = async () => {
    try {
      const values = await testForm.validateFields();
      setTestingEmail(true);

      const response = await slackConfigApi.getUserByEmail(values.email);
      message.success({
        content: (
          <div>
            <strong>사용자 조회 성공</strong>
            <br />
            이름: {response.data.realName} (@{response.data.name})
            <br />
            Slack ID: {response.data.id}
            <br />
            이메일: {response.data.email}
          </div>
        ),
        duration: 8,
      });
      testForm.resetFields();
    } catch (error: any) {
      message.error('조회 실패: ' + (error.response?.data?.error || error.message));
    } finally {
      setTestingEmail(false);
    }
  };

  // Test DM sending
  const handleTestDm = async () => {
    try {
      const values = await dmForm.validateFields();
      setTestingDm(true);

      const response = await slackConfigApi.sendDirectMessageByEmail(values.email, values.message);
      message.success({
        content: (
          <div>
            <strong>DM 발송 성공</strong>
            <br />
            사용자 ID: {response.data.userId}
            <br />
            타임스탬프: {response.data.timestamp}
          </div>
        ),
        duration: 5,
      });
      dmForm.resetFields();
    } catch (error: any) {
      message.error('발송 실패: ' + (error.response?.data?.error || error.message));
    } finally {
      setTestingDm(false);
    }
  };

  const columns: ColumnsType<SlackConfig> = [
    {
      title: '이름',
      dataIndex: 'name',
      key: 'name',
      render: (name: string) => <strong>{name}</strong>,
    },
    {
      title: 'Bot Token',
      dataIndex: 'botToken',
      key: 'botToken',
      render: (token: string) => (
        <Text code style={{ fontSize: '12px' }}>
          {token}
        </Text>
      ),
    },
    {
      title: 'App ID',
      dataIndex: 'appId',
      key: 'appId',
      render: (appId?: string) => appId || '-',
    },
    {
      title: '상태',
      dataIndex: 'isActive',
      key: 'isActive',
      render: (isActive: boolean) => (
        <Tag color={isActive ? 'success' : 'default'}>
          {isActive ? '활성' : '비활성'}
        </Tag>
      ),
    },
    {
      title: '작업',
      key: 'action',
      render: (_, record) => (
        <Space>
          <Button
            size="small"
            icon={<SyncOutlined />}
            onClick={() => handleTest(record.id, record.name)}
            loading={testingIds.has(record.id)}
          >
            테스트
          </Button>
          <Button
            size="small"
            icon={<EditOutlined />}
            onClick={() => handleEdit(record)}
          >
            수정
          </Button>
          <Popconfirm
            title="Slack 설정 삭제"
            description={`"${record.name}" 설정을 삭제하시겠습니까?`}
            onConfirm={() => handleDelete(record.id, record.name)}
            okText="삭제"
            cancelText="취소"
            okButtonProps={{ danger: true }}
          >
            <Button
              size="small"
              danger
              icon={<DeleteOutlined />}
            >
              삭제
            </Button>
          </Popconfirm>
        </Space>
      ),
    },
  ];

  return (
    <div>
      <Card
        title={
          <Space>
            <SlackOutlined />
            <span>Slack 알림</span>
          </Space>
        }
        extra={
          <Button
            type="primary"
            icon={<PlusOutlined />}
            onClick={handleAdd}
          >
            새 설정
          </Button>
        }
      >
        <Table
          columns={columns}
          dataSource={configs}
          rowKey="id"
          loading={loading}
          pagination={{
            pageSize: 10,
            showSizeChanger: true,
            showTotal: (total) => `전체 ${total}개`,
          }}
        />

        <Divider />

        <Title level={5}>테스트 기능</Title>
        <Space size="middle">
          <Button
            icon={<UserOutlined />}
            onClick={() => setTestEmailModalOpen(true)}
          >
            이메일로 Slack 사용자 조회
          </Button>
          <Button
            icon={<SendOutlined />}
            onClick={() => setTestDmModalOpen(true)}
          >
            테스트 DM 발송
          </Button>
        </Space>
      </Card>

      {/* Add/Edit Config Modal */}
      <Modal
        title={editingConfig ? 'Slack 설정 수정' : 'Slack 설정 추가'}
        open={modalOpen}
        onOk={handleModalOk}
        onCancel={handleModalCancel}
        width={700}
        okText="저장"
        cancelText="취소"
      >
        <Form
          form={form}
          layout="vertical"
          style={{ marginTop: 24 }}
        >
          <Form.Item
            name="name"
            label="설정 이름"
            rules={[{ required: true, message: '설정 이름을 입력하세요' }]}
          >
            <Input placeholder="예: 메인 워크스페이스" />
          </Form.Item>

          <Form.Item
            name="botToken"
            label="Bot Token (OAuth)"
            rules={[{ required: true, message: 'Bot Token을 입력하세요' }]}
            tooltip="xoxb-로 시작하는 Slack Bot OAuth Token"
          >
            <Input.Password placeholder="xoxb-..." />
          </Form.Item>

          <Form.Item
            name="userToken"
            label="User Token"
            tooltip="xapp-로 시작하는 Slack User Token (선택사항)"
          >
            <Input.Password placeholder="xapp-..." />
          </Form.Item>

          <Form.Item
            name="appId"
            label="App ID"
          >
            <Input placeholder="A09MJJ70Y4C" />
          </Form.Item>

          <Form.Item
            name="clientId"
            label="Client ID"
          >
            <Input placeholder="7493581335524.9732619032148" />
          </Form.Item>

          <Form.Item
            name="clientSecret"
            label="Client Secret"
          >
            <Input.Password />
          </Form.Item>

          <Form.Item
            name="signingSecret"
            label="Signing Secret"
            tooltip="요청 검증을 위한 Signing Secret (선택사항)"
          >
            <Input.Password />
          </Form.Item>

          <Form.Item
            name="verificationToken"
            label="Verification Token"
            tooltip="이전 방식의 검증 토큰 (deprecated, 선택사항)"
          >
            <Input.Password />
          </Form.Item>

          <Form.Item
            name="isActive"
            label="활성 상태"
            valuePropName="checked"
            tooltip="활성화하면 다른 설정은 자동으로 비활성화됩니다"
          >
            <Switch />
          </Form.Item>
        </Form>
      </Modal>

      {/* Test Email Lookup Modal */}
      <Modal
        title="이메일로 Slack 사용자 조회"
        open={testEmailModalOpen}
        onOk={handleTestEmail}
        onCancel={() => {
          setTestEmailModalOpen(false);
          testForm.resetFields();
        }}
        okText="조회"
        cancelText="취소"
        confirmLoading={testingEmail}
      >
        <Form
          form={testForm}
          layout="vertical"
          style={{ marginTop: 24 }}
        >
          <Form.Item
            name="email"
            label="이메일 주소"
            rules={[
              { required: true, message: '이메일을 입력하세요' },
              { type: 'email', message: '올바른 이메일 형식이 아닙니다' },
            ]}
          >
            <Input placeholder="user@example.com" />
          </Form.Item>
        </Form>
      </Modal>

      {/* Test DM Sending Modal */}
      <Modal
        title="테스트 DM 발송"
        open={testDmModalOpen}
        onOk={handleTestDm}
        onCancel={() => {
          setTestDmModalOpen(false);
          dmForm.resetFields();
        }}
        okText="발송"
        cancelText="취소"
        confirmLoading={testingDm}
      >
        <Form
          form={dmForm}
          layout="vertical"
          style={{ marginTop: 24 }}
        >
          <Form.Item
            name="email"
            label="수신자 이메일"
            rules={[
              { required: true, message: '이메일을 입력하세요' },
              { type: 'email', message: '올바른 이메일 형식이 아닙니다' },
            ]}
          >
            <Input placeholder="user@example.com" />
          </Form.Item>

          <Form.Item
            name="message"
            label="메시지"
            rules={[{ required: true, message: '메시지를 입력하세요' }]}
          >
            <TextArea
              rows={4}
              placeholder="테스트 DM ✅"
            />
          </Form.Item>
        </Form>
      </Modal>
    </div>
  );
};

export default SlackNotification;
