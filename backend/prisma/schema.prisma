generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id             String   @id
  name           String
  code           String   @unique
  phone          String?
  email          String?
  businessNumber String?
  representative String?
  address        String?
  description    String?
  logoUrl        String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  Item           Item[]
}

model Item {
  id                          String       @id
  type                        ItemType
  name                        String
  status                      ItemStatus   @default(NOT_STARTED)
  progress                    Float        @default(0)
  isOnHold                    Boolean      @default(false)
  startDate                   DateTime?
  endDate                     DateTime?
  timeSpent                   Float        @default(0)
  description                 String?
  order                       Int          @default(0)
  clientId                    String?
  parentId                    String?
  serviceTeamId               String?
  assigneeId                  String?
  createdById                 String
  isDeleted                   Boolean      @default(false)
  deletedAt                   DateTime?
  deletedById                 String?
  createdAt                   DateTime     @default(now())
  updatedAt                   DateTime
  User_Item_assigneeIdToUser  User?        @relation("Item_assigneeIdToUser", fields: [assigneeId], references: [id])
  Client                      Client?      @relation(fields: [clientId], references: [id])
  User_Item_createdByIdToUser User         @relation("Item_createdByIdToUser", fields: [createdById], references: [id])
  User_Item_deletedByIdToUser User?        @relation("Item_deletedByIdToUser", fields: [deletedById], references: [id])
  ServiceTeam                 ServiceTeam? @relation("ServiceTeamActions", fields: [serviceTeamId], references: [id], onDelete: SetNull)
  Item                        Item?        @relation("ItemToItem", fields: [parentId], references: [id], onDelete: SetNull)
  other_Item                  Item[]       @relation("ItemToItem")
  ServiceTeamsAsService       ServiceTeam[] @relation("ServiceTeamService")
  Comment                     Comment[]
  File                        File[]
  Link                        Link[]
  WorkRequest                 WorkRequest?  @relation("WorkRequestAction")
  WorkRequestAsProject        WorkRequest[] @relation("WorkRequestProject")
  WorkRequestAsService        WorkRequest[] @relation("WorkRequestService")
  WorkRequestAsTeam           WorkRequest[] @relation("WorkRequestTeam")
  WorkRequestCreatedItem      WorkRequest[] @relation("WorkRequestCreatedItem")

  @@index([assigneeId])
  @@index([clientId])
  @@index([parentId])
  @@index([serviceTeamId])
  @@index([status])
  @@index([type])
  @@index([isDeleted])
  @@index([deletedById])
}

model Project {
  id          String   @id
  name        String
  description String?
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  User        User     @relation(fields: [ownerId], references: [id])

  @@index([ownerId])
}

model SlackNotification {
  id      String   @id
  channel String
  message String
  itemId  String?
  sentAt  DateTime @default(now())
  success Boolean  @default(true)
  error   String?
}

model WorkRequest {
  id             String              @id
  title          String
  description    String
  priority       WorkRequestPriority @default(MEDIUM)
  status         WorkRequestStatus   @default(PENDING)
  dueDate        DateTime?
  projectId      String?
  serviceId      String?
  teamId         String?
  requesterId    String
  assigneeId     String?
  assigneeTeamId String?
  isRecalled          Boolean             @default(false)
  isApproved          Boolean             @default(false)
  approvedAt          DateTime?
  approvedById        String?
  rejectedAt          DateTime?
  rejectedById        String?
  rejectionMessage    String?
  negotiationMessage  String?
  negotiationAt       DateTime?
  negotiationById     String?
  actionId            String?             @unique

  // Hierarchical workflow fields
  requestType         WorkRequestType     @default(ACTION_REQUEST)
  parentWorkRequestId String?
  targetItemType      ItemType?
  createdItemId       String?

  // Soft delete fields
  isDeleted           Boolean             @default(false)
  deletedAt           DateTime?
  deletedById         String?

  createdAt           DateTime            @default(now())
  updatedAt           DateTime

  Requester      User                @relation("WorkRequestRequester", fields: [requesterId], references: [id])
  Assignee       User?               @relation("WorkRequestAssignee", fields: [assigneeId], references: [id])
  AssigneeTeam   Team?               @relation("WorkRequestAssigneeTeam", fields: [assigneeTeamId], references: [id])
  ApprovedBy     User?               @relation("WorkRequestApprovedBy", fields: [approvedById], references: [id])
  DeletedBy      User?               @relation("WorkRequest_deletedByIdToUser", fields: [deletedById], references: [id])
  Action         Item?               @relation("WorkRequestAction", fields: [actionId], references: [id])
  Project        Item?               @relation("WorkRequestProject", fields: [projectId], references: [id], onDelete: SetNull)
  Service        Item?               @relation("WorkRequestService", fields: [serviceId], references: [id], onDelete: SetNull)
  Team           Item?               @relation("WorkRequestTeam", fields: [teamId], references: [id], onDelete: SetNull)

  // Hierarchical workflow relations
  ParentWorkRequest  WorkRequest?        @relation("WorkRequestChain", fields: [parentWorkRequestId], references: [id], onDelete: SetNull)
  ChildWorkRequests  WorkRequest[]       @relation("WorkRequestChain")
  CreatedItem        Item?               @relation("WorkRequestCreatedItem", fields: [createdItemId], references: [id], onDelete: SetNull)

  @@index([requesterId])
  @@index([assigneeId])
  @@index([assigneeTeamId])
  @@index([approvedById])
  @@index([actionId])
  @@index([status])
  @@index([priority])
  @@index([projectId])
  @@index([serviceId])
  @@index([teamId])
  @@index([parentWorkRequestId])
  @@index([requestType])
  @@index([createdItemId])
  @@index([isDeleted])
  @@index([deletedById])
}

enum WorkRequestPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum WorkRequestStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REJECTED
  IN_NEGOTIATION
}

enum WorkRequestType {
  ACTION_REQUEST
  SERVICE_CREATE
  TEAM_CREATE
  IN_NEGOTIATION
}

model SystemSetting {
  id          String   @id
  key         String   @unique
  value       String
  category    String   @default("general")
  isEncrypted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([category])
  @@index([key])
}

model User {
  id                          String         @id
  username                    String         @unique
  email                       String         @unique
  displayName                 String
  phoneNumber                 String?
  ldapDn                      String?
  role                        UserRole       @default(MEMBER)
  teamId                      String?
  organizationId              String?
  title                       String?        // 직위 (대리, 과장, 부장 등)
  position                    String?        // 직책 원본 텍스트 (LDAP employeeType)
  positionType                PositionType   @default(NONE)  // 직책 enum (v1.1.20)
  roleOverride                UserRole?      // 역할 수동 override (null이면 직책 기반 자동 계산)
  departmentNumber            String?        // 부서 코드
  isVerified                  Boolean        @default(false)
  isActive                    Boolean        @default(true)
  approvalRequested           Boolean        @default(false)
  approvalRequestedAt         DateTime?
  approvalMessage             String?
  createdAt                   DateTime       @default(now())
  updatedAt                   DateTime
  Item_Item_assigneeIdToUser  Item[]         @relation("Item_assigneeIdToUser")
  Item_Item_createdByIdToUser Item[]         @relation("Item_createdByIdToUser")
  Item_Item_deletedByIdToUser Item[]         @relation("Item_deletedByIdToUser")
  Project                     Project[]
  Comment                     Comment[]
  DeletedComments             Comment[]      @relation("Comment_deletedByIdToUser")
  NotificationsFrom           Notification[] @relation("NotificationFrom")
  NotificationsTo             Notification[] @relation("NotificationTo")
  MessagesFrom                Message[]      @relation("MessageFrom")
  MessagesTo                  Message[]      @relation("MessageTo")
  UploadedFiles               File[]         @relation("FileUploadedBy")
  DeletedFiles                File[]         @relation("File_deletedByIdToUser")
  CreatedLinks                Link[]         @relation("LinkCreatedBy")
  DeletedLinks                Link[]         @relation("Link_deletedByIdToUser")
  RequestedWorks              WorkRequest[]    @relation("WorkRequestRequester")
  AssignedWorks               WorkRequest[]    @relation("WorkRequestAssignee")
  ApprovedWorks               WorkRequest[]    @relation("WorkRequestApprovedBy")
  DeletedWorkRequests         WorkRequest[]    @relation("WorkRequest_deletedByIdToUser")
  CreatedSnapshots            ReportSnapshot[] @relation("SnapshotCreatedBy")
  CreatedFeedbacks            Feedback[]       @relation("FeedbackCreatedBy")
  ResolvedFeedbacks           Feedback[]       @relation("FeedbackResolvedBy")
  Team                        Team?            @relation(fields: [teamId], references: [id])
  Organization                Organization?    @relation(fields: [organizationId], references: [id])

  @@index([teamId])
  @@index([organizationId])
  @@index([role])
  @@index([isVerified])
  @@index([approvalRequested])
}

enum ItemStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ON_HOLD
}

enum ItemType {
  PROJECT
  SERVICE
  TEAM
  ACTION
}

enum UserRole {
  ADMIN
  PO
  PM
  MEMBER
}

// 직책 enum (v1.1.20: 직책 기반 역할 매핑)
enum PositionType {
  NONE          // 직책 없음 (일반 사원)
  PART_LEADER   // 파트장 → PM
  TEAM_LEADER   // 팀장 → PM
  DIRECTOR      // 실장 → PO
  HEAD          // 본부장 → PO
  EXECUTIVE     // 이사 → PO
  SENIOR_EXEC   // 상무 → PO
  VICE_PRES     // 전무 → PO
}

model Team {
  id                      String        @id
  name                    String        @unique
  ldapDn                  String?       @unique
  departmentNumber        String?       @unique  // v1.1.19: LDAP departmentNumber (DEPT001~DEPT014)
  description             String?
  isActive                Boolean       @default(true)
  createdAt               DateTime      @default(now())
  updatedAt               DateTime

  // 계층형 구조 필드 (v1.1.18)
  parentId                String?
  level                   Int           @default(0)
  ldapType                String?

  // 계층형 관계 (자체 참조)
  Parent                  Team?         @relation("TeamHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  Children                Team[]        @relation("TeamHierarchy")

  // 기존 관계
  User                    User[]
  AssignedWorkRequests    WorkRequest[] @relation("WorkRequestAssigneeTeam")
  ServiceTeams            ServiceTeam[]

  @@index([parentId])
}

model ServiceTeam {
  id          String   @id
  serviceId   String
  teamId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  Service     Item     @relation("ServiceTeamService", fields: [serviceId], references: [id], onDelete: Cascade)
  Team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  Actions     Item[]   @relation("ServiceTeamActions")

  @@unique([serviceId, teamId])
  @@index([serviceId])
  @@index([teamId])
}

model LdapConfig {
  id                        String    @id
  name                      String    @unique
  host                      String
  port                      Int       @default(389)
  protocol                  String    @default("LDAP")
  bindDn                    String
  bindPassword              String
  searchBase                String
  searchFilter              String?
  timeout                   Int       @default(30)
  enableDynamicUserCreation Boolean   @default(true)
  attributeLoginId          String    @default("uid")
  attributeName             String    @default("cn")
  attributeSurname          String    @default("sn")
  attributeEmail            String    @default("Email")
  isActive                  Boolean   @default(true)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime

  // v1.1.18: 계층형 구조 지원 및 개선
  rootOu                    String?   @default("Organizations")
  description               String?
  lastTestedAt              DateTime?
  lastTestSuccess           Boolean?

  // v1.1.19: 확장된 LDAP 설정
  userBaseDn                String?   // 사용자 검색 Base DN (예: ou=people,dc=ldap,dc=dztechwill,dc=com)
  orgBaseDn                 String?   // 조직 검색 Base DN (예: ou=organization,dc=ldap,dc=dztechwill,dc=com)
  searchScope               String    @default("sub") // 검색 범위: sub, one, base
  filterActiveOnly          Boolean   @default(true)  // 재직자만 조회
  filterEmailRequired       Boolean   @default(false) // 이메일 있는 사용자만
  hiddenOrgs                String?   // 숨길 조직 (쉼표 구분, 예: "퇴사자,테스트팀")
  maxDepth                  Int       @default(10)    // 최대 계층 깊이 (1~20)
  showRootOu                Boolean   @default(false) // 루트 OU 표시 여부
  sortOrder                 String    @default("name") // 정렬: name, department, title
  displayNameFormat         String    @default("{sn}{cn}") // 이름 표시 형식
  attributeTitle            String    @default("title") // 직위 속성
  attributeDepartment       String    @default("ou")    // 부서 속성
  attributeDeptNumber       String    @default("departmentNumber") // 부서 코드 속성

  @@index([name])
}

model SlackConfig {
  id                String   @id
  name              String   @unique
  botToken          String
  userToken         String?
  signingSecret     String?
  verificationToken String?
  appId             String?
  clientId          String?
  clientSecret      String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime

  @@index([name])
}

enum NotificationAppType {
  SLACK
  TELEGRAM
  DISCORD
  LINE
  KAKAOTALK
}

model NotificationApp {
  id           String              @id
  name         String              @unique
  type         NotificationAppType
  config       String              // JSON string for platform-specific config
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime

  @@index([name])
  @@index([type])
}

model Permission {
  id        String   @id
  role      UserRole
  resource  String
  canView   Boolean  @default(false)
  canCreate Boolean  @default(false)
  canUpdate Boolean  @default(false)
  canDelete Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@unique([role, resource])
  @@index([role])
  @@index([resource])
}

model Comment {
  id        String   @id
  content   String
  itemId    String
  userId    String
  reactions String?  @default("{}")  // JSON: {"👍": ["userId1", "userId2"], "❤️": ["userId3"]}
  isDeleted Boolean  @default(false)
  deletedAt DateTime?
  deletedById String?
  createdAt DateTime @default(now())
  updatedAt DateTime
  Item      Item     @relation(fields: [itemId], references: [id], onDelete: SetNull)
  User      User     @relation(fields: [userId], references: [id])
  DeletedBy User?    @relation("Comment_deletedByIdToUser", fields: [deletedById], references: [id])

  @@index([itemId])
  @@index([userId])
  @@index([isDeleted])
  @@index([deletedById])
}

model Notification {
  id        String   @id
  type      String   // 'comment_mention', 'comment_reply', etc.
  content   String
  itemId    String?
  commentId String?
  fromUserId String
  toUserId  String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  FromUser  User     @relation("NotificationFrom", fields: [fromUserId], references: [id])
  ToUser    User     @relation("NotificationTo", fields: [toUserId], references: [id])

  @@index([toUserId])
  @@index([isRead])
}

model Message {
  id         String    @id
  subject    String
  content    String
  fromUserId String
  toUserId   String
  isRead     Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  FromUser   User      @relation("MessageFrom", fields: [fromUserId], references: [id])
  ToUser     User      @relation("MessageTo", fields: [toUserId], references: [id])

  @@index([fromUserId])
  @@index([toUserId])
  @@index([isRead])
}

model File {
  id           String   @id
  filename     String
  originalName String
  filepath     String
  filesize     Int
  mimetype     String
  itemId       String
  projectId    String?
  serviceId    String?
  teamId       String?
  uploadedById String
  isDeleted    Boolean  @default(false)
  deletedAt    DateTime?
  deletedById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  Item         Item     @relation(fields: [itemId], references: [id], onDelete: SetNull)
  UploadedBy   User     @relation("FileUploadedBy", fields: [uploadedById], references: [id])
  DeletedBy    User?    @relation("File_deletedByIdToUser", fields: [deletedById], references: [id])

  @@index([itemId])
  @@index([uploadedById])
  @@index([projectId])
  @@index([serviceId])
  @@index([teamId])
  @@index([isDeleted])
  @@index([deletedById])
}

model Link {
  id           String   @id
  url          String
  displayName  String
  itemId       String
  projectId    String?
  serviceId    String?
  teamId       String?
  createdById  String
  isDeleted    Boolean  @default(false)
  deletedAt    DateTime?
  deletedById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  Item         Item     @relation(fields: [itemId], references: [id], onDelete: SetNull)
  CreatedBy    User     @relation("LinkCreatedBy", fields: [createdById], references: [id])
  DeletedBy    User?    @relation("Link_deletedByIdToUser", fields: [deletedById], references: [id])

  @@index([itemId])
  @@index([createdById])
  @@index([projectId])
  @@index([serviceId])
  @@index([teamId])
  @@index([isDeleted])
  @@index([deletedById])
}

model Organization {
  id          String         @id
  name        String
  type        OrgType
  description String?
  ldapDn      String?        @unique
  parentId    String?
  order       Int            @default(0)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime
  Parent      Organization?  @relation("OrgHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  Children    Organization[] @relation("OrgHierarchy")
  Members     User[]

  @@index([parentId])
  @@index([type])
}

enum OrgType {
  COMPANY
  DIVISION
  DEPARTMENT
  TEAM
}

model ReportSnapshot {
  id          String   @id
  title       String   // Report title (e.g., "2025-01-15 프로젝트 현황")
  clientId    String
  clientName  String   // Denormalized for historical accuracy
  startDate   DateTime // Report date range start
  endDate     DateTime // Report date range end
  data        String   // JSON stringified report data (items array)
  statistics  String   // JSON stringified statistics (total, completed, etc.)
  createdById String
  createdAt   DateTime @default(now())
  CreatedBy   User     @relation("SnapshotCreatedBy", fields: [createdById], references: [id])

  @@index([clientId])
  @@index([createdById])
  @@index([createdAt])
}

// 피드백 게시판 (v1.1.27)
model Feedback {
  id            String          @id
  title         String
  content       String
  type          FeedbackType
  status        FeedbackStatus  @default(PENDING)
  adminComment  String?         // 관리자 답변
  createdById   String
  resolvedAt    DateTime?
  resolvedById  String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime

  CreatedBy     User            @relation("FeedbackCreatedBy", fields: [createdById], references: [id])
  ResolvedBy    User?           @relation("FeedbackResolvedBy", fields: [resolvedById], references: [id])

  @@index([createdById])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

enum FeedbackType {
  BUG           // 버그 신고
  FEATURE       // 기능 요청
  IMPROVEMENT   // 개선 사항
}

enum FeedbackStatus {
  PENDING       // 대기중
  IN_PROGRESS   // 진행중
  RESOLVED      // 해결됨
  REJECTED      // 반려
}
