# Database
DATABASE_URL="postgresql://psta_user:psta_password@localhost:5432/psta?schema=public"

# JWT
JWT_SECRET="your-secret-key-here"
JWT_EXPIRES_IN="24h"

# LDAP (설정은 시스템 설정 > LDAP 인증 페이지에서 관리됨)
# LDAP 설정은 데이터베이스(LdapConfig 테이블)에서 동적으로 관리됩니다

# Slack (Optional - Notification App Integration 페이지에서 관리 가능)
SLACK_BOT_TOKEN="xoxb-your-bot-token"
SLACK_SIGNING_SECRET="your-signing-secret"
SLACK_DEFAULT_CHANNEL="#psta-notifications"

# Server
PORT=3001
NODE_ENV="development"

# Frontend URL (for notification links)
FRONTEND_URL="http://192.168.1.250:3000"
